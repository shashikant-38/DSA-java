class Solution {
    public void rotateLeft(int[] arr, int k) {
        int n = arr.length;
        k = k % n;

        // Step 1: store first k elements
        int[] temp = new int[k];
        for (int i = 0; i < k; i++) {
            temp[i] = arr[i];
        }

        // Step 2: shift remaining elements left
        for (int i = k; i < n; i++) {
            arr[i - k] = arr[i];
        }

        // Step 3: put stored elements at end
        for (int i = 0; i < k; i++) {
            arr[n - k + i] = temp[i];
        }
    }
}


